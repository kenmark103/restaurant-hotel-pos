{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "composite": true,
    "outDir": "./dist"
  },
  "include": ["src"],
  "references": [
    { "path": "./tsconfig.node.json" }
  ]
}